# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=footprint
POSTGRES_USER=footprint
POSTGRES_PASSWORD=changeme

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Google OAuth2 / Photos API ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_CREDENTIALS_FILE=credentials/google_oauth_credentials.json
GOOGLE_TOKEN_FILE=credentials/google_token.json
GOOGLE_SCOPES=https://www.googleapis.com/auth/photoslibrary.readonly

# ── Google Takeout ────────────────────────────────────────────────────────────
# Path to extracted Takeout directory
TAKEOUT_PATH=/data/takeout/Google Photos

# ── Storage ───────────────────────────────────────────────────────────────────
MEDIA_CACHE_DIR=/data/media_cache
MEDIA_CACHE_MAX_GB=50

# ── Enrichment ────────────────────────────────────────────────────────────────
ENRICHMENT_CONCURRENCY=5
# Must match vector(N) in schema.sql — 512 for CLIP ViT-B/32
EMBEDDING_DIM=512

# ── Geocoding ─────────────────────────────────────────────────────────────────
NOMINATIM_USER_AGENT=footprint/0.1.0

# ── Streamlit UI ──────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
DEBUG=false
